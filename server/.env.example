# Database
DATABASE_URL=postgresql://user:password@localhost:5432/streetdice
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=YourBotUsername  # For referral links (without @)
APP_SHORT_NAME=app            # Your Mini App short name from BotFather

# Yandex Games
# Private signature secret from the Yandex Games developer console
# (https://yandex.com/dev/games/doc/en/console/integration). Required to
# verify `player.signature` payloads from the Yandex Games SDK. When this
# is empty the server falls back to an unsigned, dev-only "parse unsafe"
# path so local development isn't blocked.
YANDEX_APP_SECRET=

# Server
PORT=3001
WS_PORT=3002

# Admin Dashboard
ADMIN_PASSWORD=your_secure_password_here

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info  # debug, info, warn, error
